rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the authenticated user has role "admin"
    function isAdmin() {
      return request.auth != null
             && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // --- users/{uid} ---
    match /users/{userId} {
      // Users can read their own profile; admins can read any profile
      allow read: if request.auth != null
                  && (request.auth.uid == userId || isAdmin());

      // Users can create their own profile during sign-up
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.uid == userId
                    && request.resource.data.role == "student"
                    && request.resource.data.keys().hasAll(["uid", "name", "email", "phone", "role", "createdAt"]);

      // Only admins can update user profiles (e.g. changing role)
      allow update: if isAdmin();

      // No client-side deletes
      allow delete: if false;
    }

    // --- enrollments/{enrollmentId} ---
    match /enrollments/{enrollmentId} {
      // Users can read their own enrollments; admins can read any enrollment
      allow read: if request.auth != null
                  && (resource.data.uid == request.auth.uid || isAdmin());

      // Users can create enrollments for themselves with status "pending"
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.status == "pending"
                    && request.resource.data.courseId in [
                         "1_year_foundation",
                         "2_year_foundation",
                         "3_year_foundation",
                         "apmc_1_0",
                         "apmc_2_0",
                         "csat",
                         "psir",
                         "kannada_literature",
                         "anthropology",
                         "gold_standard",
                         "mains_mentorship",
                         "daily_answer_writing"
                       ]
                    && request.resource.data.keys().hasAll(["uid", "courseId", "courseName", "status", "submittedAt"]);

      // Only admins can update enrollments (approve/deny)
      // Admin can only change status and reviewedAt, nothing else
      allow update: if isAdmin()
                    && request.resource.data.status in ["approved", "denied"]
                    && request.resource.data.uid == resource.data.uid
                    && request.resource.data.courseId == resource.data.courseId
                    && request.resource.data.courseName == resource.data.courseName
                    && request.resource.data.submittedAt == resource.data.submittedAt;

      // No client-side deletes
      allow delete: if false;
    }

    // --- courses/{courseId}/videos/{videoId} --- (read-only for authenticated users)
    match /courses/{courseId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();

      match /videos/{videoId} {
        allow read: if request.auth != null;
        allow write: if isAdmin();
      }
    }

    // --- catalog/** --- (folder→subject→course mapping; sync function writes via Admin SDK)
    match /catalog/{doc=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // --- rateLimits/{uid} --- (server-only, managed by Cloud Functions)
    match /rateLimits/{userId} {
      allow read, write: if false;
    }

    // --- enquiries/{doc} --- (webapp contact form; admin-only read)
    match /enquiries/{doc} {
      allow create: if true;
      allow read: if isAdmin();
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
